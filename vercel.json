{
  "version": 2,
  "builds": [
    { "src": "api/auth.js", "use": "@vercel/node" },
    { "src": "api/matches.js", "use": "@vercel/node" },
    { "src": "api/statistics.js", "use": "@vercel/node" },
    { "src": "api/strategies.js", "use": "@vercel/node" },
    { "src": "api/ocr.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "login.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth", "dest": "api/auth.js" },
    { "src": "/api/matches", "dest": "api/matches.js" },
    { "src": "/api/statistics", "dest": "api/statistics.js" },
    { "src": "/api/strategies", "dest": "api/strategies.js" },
    { "src": "/api/ocr", "dest": "api/ocr.js" },
    { "src": "/login.html", "dest": "/login.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}