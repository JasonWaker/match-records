{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/auth", "dest": "api/auth.js" },
    { "src": "/api/matches", "dest": "api/matches.js" },
    { "src": "/api/statistics", "dest": "api/statistics.js" },
    { "src": "/api/strategies", "dest": "api/strategies.js" },
    { "src": "/api/ocr", "dest": "api/ocr.js" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/login.html", "dest": "/login.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}